# Use 127.0.0.1 on Windows if localhost:3000 is flaky (IPv6 / DNS).
# Android emulator: keep 127.0.0.1 here — the app maps it to 10.0.2.2 automatically so requests reach your PC.
# Physical Android device (Expo Go on a phone): set your PC LAN IP, e.g. EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# Vercel: set to your Next.js API origin, e.g. https://nurture-ai-xxxx.vercel.app — not the Expo web URL.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Vercel: add the same EXPO_PUBLIC_* keys under Project → Settings → Environment Variables
# (Production + Preview) or static export will bundle placeholders and auth/API will not work.
#
# Copy to .env and restart Expo after changes (EXPO_PUBLIC_* is baked in at bundle time).
# The Next.js API must be running separately: from the nurtureai/ folder run `npm run dev` (default http://localhost:3000).
# Optional: raise mobile fetch timeout for slow AI routes (ms, 5000–180000). Default 45000.
# EXPO_PUBLIC_API_TIMEOUT_MS=120000
#
# Dev server: default `npm start` runs Expo with --offline and IPv4-first DNS (see package.json) to avoid Windows "fetch failed" during Metro startup. Use `npm run start:online` for tunnel / full network features.
