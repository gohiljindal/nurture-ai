# Copy this file to `.env` or `.env.local` on your machine. Do not commit real secrets.
#
# Task 1 (local Docker Postgres): you only need DATABASE_URL below for the database to match
# docker-compose.yml. Fill in the Supabase lines when you run the full app against Supabase.
#
# Task 2 (Prisma): with Docker Postgres running — `npm run db:generate` (also runs on `npm install`)
# then `npm run db:deploy` to apply migrations. Check sync with `npm run db:status`.
#
# Task 4 (Auth — Supabase):
# 1. Create a project at https://supabase.com → Settings → API: copy Project URL and anon public key.
# 2. Authentication → URL: set Site URL to http://localhost:3000 (and add the same to Redirect URLs for dev).
# 3. Paste into `.env.local` below and restart `npm run dev`. Never commit `.env.local`.
# The anon key is designed to be public (RLS still applies in Supabase); do not put the service_role key here.
#
# Child profile photos: create a public Storage bucket named `child-photos` (Dashboard → Storage),
# then run supabase/manual/child-photos-storage-policies.sql in the SQL Editor. Bucket name is in lib/child-photo-upload-error.ts.

# --- Supabase (Task 4 — required for login / signup / protected pages)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Local PostgreSQL (Docker) — user, password, db, host, port must match docker-compose.yml
DATABASE_URL="postgresql://nurture:nurture_dev_local@localhost:5432/nurtureai?schema=public"
